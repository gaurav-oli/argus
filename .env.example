# ─────────────────────────────────────────────────────────────
# Argus — Environment Variables TEMPLATE
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in real values in .env (NEVER in this .example file)
# 3. .env is gitignored and will never be committed
#

# Leave a value blank if you don't have it yet — the platform
# degrades gracefully and only the dependent feature is affected.
# ─────────────────────────────────────────────────────────────

# ===== MVP — REQUIRED =========================================

# Finnhub — the linchpin: stock prices (WebSocket), news, USD/CAD FX,
# VIX, earnings calendar, IPO calendar. Free tier.
# Sign up: https://finnhub.io/register → Dashboard → API key
FINNHUB_API_KEY=

# Anthropic (Claude Haiku) — Agent 5 final recommendation output.
# This is the ONLY recurring paid API (~$5-10 USD/month).
# Sign up: https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=

# ===== MVP — NO KEY NEEDED (here for reference) ===============
# GDELT (global news) — no auth
# RSS feeds (Reuters/AP) — no auth
# Ollama (local models) — runs on host, no key
# SEC EDGAR — no key, but requires a descriptive
# User-Agent header (your email). Used in Phase 2.
SEC_EDGAR_USER_AGENT=Argus/1.0 (your-email@example.com)

# ===== PHASE 2 — fill in later ================================

# Alpha Vantage — supplementary fundamentals. Free tier.
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Reddit API — social sentiment (Agent 2). Free.
# https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=Argus/1.0 by your-reddit-username

# StockTwits — social sentiment (Agent 2). Free.
# https://api.stocktwits.com (register an application)
STOCKTWITS_ACCESS_TOKEN=

# ===== PHASE 3 — fill in later ================================

# QuantConnect — backtesting (Agent 5 full). Free.
# https://www.quantconnect.com/account
QUANTCONNECT_USER_ID=
QUANTCONNECT_API_TOKEN=

# ===== APP / DB SECRETS (you choose these — not external) =====
# Local Postgres credentials for Docker Compose.
# IMPORTANT: the backend's application.yml defaults to these exact values
# (user/db/password = argus) and Spring does NOT read this .env file, so for
# local `mvn spring-boot:run` keep POSTGRES_PASSWORD = argus (or also export it
# to the backend's environment). On the Mac Mini, set a real password here AND
# in the backend's runtime environment so both halves match.
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus
POSTGRES_DB=argus

# Argus app login PIN is set in-app (FR-35), not here.

# ===== DEPLOY — Mac Mini only (Story 1.8) =====================
# These drive the `deploy` compose profile + the frontend build. On the dev
# laptop you can ignore them (the dev workflow is DBs-only). See
# docs/deploy-runbook.md.

# Spring profile for the backend container. `prod` routes the Model Gateway to
# Ollama (Gemma) on the host. The compose default is already `prod`.
SPRING_PROFILES_ACTIVE=prod

# Native Ollama on the Mini, reached from the backend container via the Docker
# host gateway. Change only if Ollama listens elsewhere.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Big model tag + keep-alive — VALIDATED by the Story 1.3 RAM/latency spike on the
# Mini (2026-06-21). gemma4:26b is ~17GB resident; the 26B + full stack overflows
# the 28GB Mini into swap, so keep-alive is short (unload-when-idle): the model
# frees ~17GB when idle and reloads on demand (~28s cold-load accepted). Do NOT
# pin it resident (-1) on a 28GB box.
ARGUS_BIG_MODEL=gemma4:26b
ARGUS_MODEL_KEEP_ALIVE=5m

# Browser origins allowed to call the API (CORS), comma-separated. On the Mini set this to your
# tailnet host — behind `tailscale serve` the backend sees same-origin browser POSTs as
# cross-origin, so the deployed origin must be listed or login/setup POSTs are rejected 403.
# Example: ARGUS_WEB_ALLOWED_ORIGINS=https://mini.your-tailnet.ts.net
ARGUS_WEB_ALLOWED_ORIGINS=http://localhost:3000

# WebAuthn / passkey biometric unlock (Story 2.2). RP ID must be the effective domain and a
# registrable suffix of the origin. On the Mini set both to your tailnet host:
#   ARGUS_SECURITY_WEBAUTHN_RP_ID=mini.your-tailnet.ts.net
#   ARGUS_SECURITY_WEBAUTHN_ORIGINS=https://mini.your-tailnet.ts.net
ARGUS_SECURITY_WEBAUTHN_RP_ID=localhost
ARGUS_SECURITY_WEBAUTHN_ORIGINS=http://localhost:3000

# Frontend build-time API/WS base (inlined into the bundle). For the recommended
# single-origin Tailscale-serve setup, leave the API base EMPTY (same-origin /api)
# and point the WS URL at your tailnet host. Example:
# NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_WS_URL=wss://mini.your-tailnet.ts.net/ws
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WS_URL=

# ---- Epic 8: Push notifications & Morning Briefing ----
#
# Web Push (FR-17) uses VAPID — a stable EC P-256 keypair the backend signs push
# requests with. The PUBLIC key is shared with the browser (not secret) and is baked
# into every subscription, so it MUST stay constant once devices subscribe. The PRIVATE
# key is a secret: keep it ONLY in the real .env (never commit it).
#
# Bound in code as argus.push.vapid.{public-key,private-key,subject}. Regenerate with:
#   node -e 'const{webcrypto:c}=require("crypto");const u=b=>Buffer.from(b).toString("base64url");
#   (async()=>{const k=await c.subtle.generateKey({name:"ECDSA",namedCurve:"P-256"},true,["sign","verify"]);
#   const p=await c.subtle.exportKey("raw",k.publicKey);const j=await c.subtle.exportKey("jwk",k.privateKey);
#   console.log("public ="+u(p));console.log("private="+u(Buffer.from(j.d,"base64url")))})()'
#
# A keypair was already generated for this project — the PUBLIC key is below; set the matching
# PRIVATE key in your real .env (it is intentionally left blank here).
ARGUS_PUSH_VAPID_PUBLIC=BPvgFcIZm00Vfg93IxUgJcu4KDn_vn6WyK53woEsd-EWVBiiJ_WGKvm8U7XYrQVa9sbLbz7oEHn0AMbBmVFvehM
ARGUS_PUSH_VAPID_PRIVATE=
ARGUS_PUSH_VAPID_SUBJECT=mailto:gauravoli16@gmail.com

# Morning Briefing (FR-16) needs no new keys — it runs on the local model (ModelGateway,
# BIG tier) on a daily 8am America/Toronto schedule and pushes via the VAPID config above.
# Backups (Stories 10.1/10.2). Dumps run on the HOST via launchd (scripts/install-backup-schedule.sh);
# the backend reads this dir (mounted ro at /backups) for status + staleness alerts.
# Currently the internal disk; when the external SSD arrives set this to /Volumes/<SSD>/argus-backups
# and re-run scripts/install-backup-schedule.sh.
ARGUS_BACKUP_HOST_DIR=/Users/leanna/argus-backups
